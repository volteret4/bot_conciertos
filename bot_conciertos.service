[Unit]
Description=Telegram Bot Conciertos
After=network.target

[Service]
Type=simple
User=pepe
WorkingDirectory=/home/pepe/gits/pollo/bot_conciertos/
EnvironmentFile=/home/pepe/gits/pollo/bot_conciertos/.env
ExecStart=/home/pepe/Scripts/python_venv/bin/python /home/pepe/gits/pollo/bot_conciertos/telegram_bot.py
Restart=always
RestartSec=10

[Install]
WantedBy=multi-user.target
